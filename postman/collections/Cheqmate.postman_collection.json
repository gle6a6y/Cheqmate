        {
          "name": "cheques",
          "item": [
            {
              "name": "200: Add Cheque To The Group",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "",
                      "// базовые проверки",
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Cheque has required fields\", function () {",
                      "    pm.expect(json).to.have.property(\"id\");",
                      "    pm.expect(json).to.have.property(\"name\");",
                      "    pm.expect(json).to.have.property(\"total\");",
                      "    pm.expect(json).to.have.property(\"owner\");",
                      "    pm.expect(json).to.have.property(\"whoPaid\");",
                      "    pm.expect(json).to.have.property(\"group\");",
                      "    pm.expect(json).to.have.property(\"proportions\");",
                      "});",
                      "",
                      "pm.test(\"Cheque main fields are correct\", function () {",
                      "    pm.expect(json.group.groupName).to.eql(\"Trip to Australia\");",
                      "    pm.expect(json.name).to.eql(\"Dinner\");",
                      "    pm.expect(json.total).to.eql(3000);",
                      "    pm.expect(json.owner.name).to.eql(\"Alice\");",
                      "    pm.expect(json.whoPaid.name).to.eql(\"Bob\");",
                      "});",
                      "",
                      "pm.test(\"Proportions object has correct members\", function () {",
                      "    pm.expect(json.proportions).to.be.an(\"object\");",
                      "",
                      "    const props = json.proportions;",
                      "    const aliceId = String(pm.environment.get(\"aliceId\"));",
                      "    const bobId = String(pm.environment.get(\"bobId\"));",
                      "    const charlieId = String(pm.environment.get(\"charlieId\"));",
                      "    const martinId = String(pm.environment.get(\"martinId\"));",
                      "",
                      "    pm.expect(props).to.have.property(aliceId);",
                      "    pm.expect(props).to.have.property(bobId);",
                      "    pm.expect(props).to.have.property(charlieId);",
                      "    pm.expect(props).to.have.property(martinId);",
                      "",
                      "    pm.expect(props[aliceId]).to.eql(15);",
                      "    pm.expect(props[bobId]).to.eql(40);",
                      "    pm.expect(props[charlieId]).to.eql(30);",
                      "    pm.expect(props[martinId]).to.eql(25);",
                      "});",
                      "",
                      "pm.environment.set(\"chequeId\", json.id);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
